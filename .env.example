GEMINI_API_KEY=your_gemini_api_key
SECRET_KEY=your_secret_key
MONGO_URI=your_mongo_uri
ACCESS_TOKEN_EXPIRE_MINUTES=60
REDIS_PASSWORD=your_redis_password
REDIS_HOSTNAME=your_redis_hostname
